# ────────────────────────────────────────────────────────────
# THE GREAT REPLACEMENT — Environment Variables
# Copy this file to `.env` and fill in your real values.
# ────────────────────────────────────────────────────────────

# Flask
FLASK_ENV=development                     # set to "production" when deploying
PORT=5000

# ─── Stripe ────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
# Start with TEST keys (sk_test_..., pk_test_...) — switch to live after launch.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret. Get this by running:
#   stripe listen --forward-to localhost:5000/webhook/stripe
# in local dev, or by creating a webhook endpoint in the dashboard for prod.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# OPTIONAL: pre-created Price ID. If empty, app creates ad-hoc prices.
STRIPE_PRICE_ID=

# Report price in cents (default 900 = $9.00)
REPORT_PRICE_CENTS=900

# ─── Public URL (used in Stripe redirect URLs) ─────────────
# Local dev:  http://localhost:5000
# Production: https://yourdomain.com
APP_BASE_URL=http://localhost:5000

# ─── Email delivery ────────────────────────────────────────
# Option A: Resend (recommended — modern API, free tier)
#   Sign up at https://resend.com, verify a domain, paste key here.
RESEND_API_KEY=

# Option B: SMTP fallback (Gmail App Password, AWS SES, Postmark, etc.)
# Used only if RESEND_API_KEY is empty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# From-address for the report email
EMAIL_FROM=Atlas Reports <reports@yourdomain.com>

# ────────────────────────────────────────────────────────────
# If both Resend and SMTP are empty, reports are saved to
# data/sent_reports/ for local inspection (dev mode).
# ────────────────────────────────────────────────────────────
